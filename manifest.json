{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.2.2",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://*.x.com/*",
    "*://twitter.com/*",
    "*://*.twitter.com/*",
    "*://threads.net/*",
    "*://*.threads.net/*",
    "*://threads.com/*",
    "*://*.threads.com/*",
    "*://bsky.app/*",
    "*://*.bsky.app/*",
    "*://mastodon.social/*",
    "*://*.mastodon.social/*",
    "*://mastodon.online/*",
    "*://*.mastodon.online/*",
    "*://mstdn.social/*",
    "*://*.mstdn.social/*",
    "*://mas.to/*",
    "*://*.mas.to/*",
    "*://mastodon.world/*",
    "*://*.mastodon.world/*",
    "*://mstdn.jp/*",
    "*://*.mstdn.jp/*",
    "*://pawoo.net/*",
    "*://*.pawoo.net/*",
    "*://reddit.com/*",
    "*://*.reddit.com/*",
    "*://linkedin.com/*",
    "*://*.linkedin.com/*",
    "*://facebook.com/*",
    "*://*.facebook.com/*",
    "*://instagram.com/*",
    "*://*.instagram.com/*",
    "*://youtube.com/*",
    "*://*.youtube.com/*",
    "*://tiktok.com/*",
    "*://*.tiktok.com/*",
    "*://discord.com/*",
    "*://*.discord.com/*",
    "*://slack.com/*",
    "*://*.slack.com/*",
    "*://web.whatsapp.com/*",
    "*://messenger.com/*",
    "*://*.messenger.com/*",
    "*://web.telegram.org/*",
    "*://github.com/*",
    "*://*.github.com/*",
    "*://line.me/*",
    "*://*.line.me/*",
    "*://chat.line.biz/*",
    "*://nicovideo.jp/*",
    "*://*.nicovideo.jp/*",
    "*://note.com/*",
    "*://*.note.com/*",
    "*://qiita.com/*",
    "*://*.qiita.com/*",
    "*://zenn.dev/*",
    "*://*.zenn.dev/*",
    "*://chatwork.com/*",
    "*://*.chatwork.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "hint.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://*.twitter.com/*",
        "*://threads.net/*",
        "*://*.threads.net/*",
        "*://threads.com/*",
        "*://*.threads.com/*",
        "*://bsky.app/*",
        "*://*.bsky.app/*",
        "*://mastodon.social/*",
        "*://*.mastodon.social/*",
        "*://mastodon.online/*",
        "*://*.mastodon.online/*",
        "*://mstdn.social/*",
        "*://*.mstdn.social/*",
        "*://mas.to/*",
        "*://*.mas.to/*",
        "*://mastodon.world/*",
        "*://*.mastodon.world/*",
        "*://mstdn.jp/*",
        "*://*.mstdn.jp/*",
        "*://pawoo.net/*",
        "*://*.pawoo.net/*",
        "*://reddit.com/*",
        "*://*.reddit.com/*",
        "*://linkedin.com/*",
        "*://*.linkedin.com/*",
        "*://facebook.com/*",
        "*://*.facebook.com/*",
        "*://instagram.com/*",
        "*://*.instagram.com/*",
        "*://youtube.com/*",
        "*://*.youtube.com/*",
        "*://tiktok.com/*",
        "*://*.tiktok.com/*",
        "*://discord.com/*",
        "*://*.discord.com/*",
        "*://slack.com/*",
        "*://*.slack.com/*",
        "*://web.whatsapp.com/*",
        "*://messenger.com/*",
        "*://*.messenger.com/*",
        "*://web.telegram.org/*",
        "*://github.com/*",
        "*://*.github.com/*",
        "*://line.me/*",
        "*://*.line.me/*",
        "*://chat.line.biz/*",
        "*://nicovideo.jp/*",
        "*://*.nicovideo.jp/*",
        "*://note.com/*",
        "*://*.note.com/*",
        "*://qiita.com/*",
        "*://*.qiita.com/*",
        "*://zenn.dev/*",
        "*://*.zenn.dev/*",
        "*://chatwork.com/*",
        "*://*.chatwork.com/*"
      ],
      "js": [
        "platforms.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
